{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/admin",       "dest": "/admin/index.html" },
    { "src": "/hr",          "dest": "/hr.html" },
    { "src": "/login",       "dest": "/login.html" },
    { "src": "/it-support",  "dest": "/it-support.html" },
    { "src": "/track",       "dest": "/track.html" },
    { "src": "/maintenance", "dest": "/maintenance.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)",        "dest": "/404.html",        "status": 404 }
  ]
}
